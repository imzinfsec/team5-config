# -------------------------------------------------------------------
# Local environment files
# -------------------------------------------------------------------
.env
.env.*
*.env

# -------------------------------------------------------------------
# Kubernetes Secret files
# 실제 비밀번호/토큰/키가 들어간 secret manifest는 올리지 않기
# 예시 파일만 Git에 올리기
# -------------------------------------------------------------------
*secret*.yaml
*secret*.yml
*secrets*.yaml
*secrets*.yml

!*secret*.example.yaml
!*secret*.example.yml
!*secrets*.example.yaml
!*secrets*.example.yml

# -------------------------------------------------------------------
# Grafana / Monitoring local secret files
# values 파일은 올려도 되지만, 비밀번호가 들어간 secret 파일은 제외
# -------------------------------------------------------------------
grafana-admin-secret.yaml
grafana-admin-secret.yml
*grafana*secret*.yaml
*grafana*secret*.yml

!*grafana*secret*.example.yaml
!*grafana*secret*.example.yml

# -------------------------------------------------------------------
# Kubeconfig / cluster access files
# -------------------------------------------------------------------
kubeconfig
kubeconfig.*
*.kubeconfig
.kube/
*.config

# -------------------------------------------------------------------
# Argo CD local/session files
# -------------------------------------------------------------------
.argocd/
argocd-context
argocd-token
argocd-session

# -------------------------------------------------------------------
# Kustomize / kubectl build output
# -------------------------------------------------------------------
kustomize-output.yaml
rendered.yaml
manifest.yaml
manifests.yaml
all.yaml
output.yaml

# -------------------------------------------------------------------
# Helm package / temporary files
# charts/ 폴더는 Helm Chart를 Git에 올릴 수도 있으므로 제외하지 않음
# -------------------------------------------------------------------
*.tgz
Chart.lock

# -------------------------------------------------------------------
# Terraform files, just in case
# team5-config에는 보통 Terraform이 없지만 실수 방지용
# -------------------------------------------------------------------
.terraform/
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
!*.tfvars.example
crash.log
crash.*.log

# -------------------------------------------------------------------
# AWS / credential files
# -------------------------------------------------------------------
.aws/
credentials
config
*.pem
*.key
*.crt
*.cer
*.p12

# -------------------------------------------------------------------
# Local temporary files
# -------------------------------------------------------------------
*.tmp
*.bak
*.backup
*.log

# -------------------------------------------------------------------
# OS files
# -------------------------------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------------------------------
# Editor files
# -------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo